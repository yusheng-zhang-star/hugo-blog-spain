# Custom headers for Cloudflare Pages - comprimefotos.com blog
# https://developers.cloudflare.com/pages/platform/headers/
#
# KEY RULE: CF Pages _headers merges ALL matching paths' same-name headers.
# So / matches BOTH "/" AND "/*" — two CDN-Cache-Control values get merged!
# Fix: only set CDN-Cache-Control on specific paths, NOT on catch-all.
#
# Strategy:
#   - Homepage/posts/ciudades/tags: CDN cache 1h, browser revalidate
#   - Static assets (CSS/JS/images): CDN cache 7d, browser cache 7d
#   - Sitemap/feed: CDN cache 30min, browser revalidate
#   - 404 pages: no CDN cache (Negative Cache R0 handles 4xx)

# 404 error page: no CDN cache
/404.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# Homepage
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# Blog posts
/posts/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# City pages
/ciudades/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# Tags pages
/tags/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# Categories pages
/categories/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# About/Contact/Privacy/License pages
/about/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
/contact/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
/privacy/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
/license/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600

# Sitemap: CDN cache 30min
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800
  Content-Type: application/xml; charset=utf-8

# Robots.txt: CDN cache 30min
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800

# RSS/Atom feed: CDN cache 30min
/index.xml
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800
  Content-Type: application/xml; charset=utf-8

# JSON search index: CDN cache 30min
/index.json
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800

# Hugo-generated assets (CSS/JS bundles): CDN cache 7d
/assets/*
  Cache-Control: public, max-age=604800
  CDN-Cache-Control: public, max-age=604800

# Images: CDN cache 30d
/images/*
  Cache-Control: public, max-age=2592000
  CDN-Cache-Control: public, max-age=2592000

# Other XML files: CDN cache 30min
/*.xml*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800
  Content-Type: application/xml; charset=utf-8

# Catch-all: browser cache 7d ONLY (no CDN-Cache-Control to avoid header merge)
/*
  Cache-Control: public, max-age=604800
